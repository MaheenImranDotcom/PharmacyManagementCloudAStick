{
    "info": {
        "name": "Pharmacy Management APIs",
        "_postman_id": "d8d9d3b7-2c2a-4b4f-9b7d-123456789abc",
        "description": "Salesforce Apex REST APIs for Pharmacy Management Assessment",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
