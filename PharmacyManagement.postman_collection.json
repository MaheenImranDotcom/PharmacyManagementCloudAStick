            "name": "Products",
            "item": [
                {
                    "name": "Get Products",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{accessToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{instanceUrl}}/services/apexrest/abc/products",
                            "host": [
                                "{{instanceUrl}}"
                            ],
                            "path": [
                                "services",
                                "apexrest",
                                "abc",
                                "products"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Shopping Cart",
            "item": [
                {
                    "name": "Create Cart",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{accessToken}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"customerCode\": \"{{customerCode}}\"\n}"
                        },
                        "url": {
                            "raw": "{{instanceUrl}}/services/apexrest/abc/cart",
                            "host": [
                                "{{instanceUrl}}"
                            ],
                            "path": [
                                "services",
