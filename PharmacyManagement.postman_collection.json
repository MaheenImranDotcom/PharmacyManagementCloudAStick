                                "abc",
                                "cart"
                            ]
                        }
                    }
                },
                {
                    "name": "Add Product To Cart",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{accessToken}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"customerCode\": \"{{customerCode}}\",\n    \"productName\": \"Paracetamol\",\n    \"quantity\": 2\n}"
                        },
                        "url": {
                            "raw": "{{instanceUrl}}/services/apexrest/abc/cart/items",
                            "host": [
                                "{{instanceUrl}}"
                            ],
                            "path": [
